# --- App ---
APP_NAME=AIRA
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
# For local dev with XAMPP MySQL (default user root, empty password):
DATABASE_URL=mysql+pymysql://root:@localhost:3306/aira
# In Docker the host becomes "mysql":
# DATABASE_URL=mysql+pymysql://aira:airapass@mysql:3306/aira

# --- Security ---
JWT_SECRET=change-this-in-production-please-32-chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760

# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- AI ---
# When false, the AI service uses a deterministic stub — useful for tests
# and for environments without torch/transformers.
AI_ENABLED=false

# --- Auto-seed (creates default admin/officer/citizen on startup) ---
AUTO_SEED=true
