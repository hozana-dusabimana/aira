# Production environment for docker-compose.prod.yml.
# Copy to .env.prod ON THE SERVER and fill in real secrets. Never commit .env.prod.
#
#   cp .env.prod.example .env.prod && nano .env.prod

# --- App ---
APP_NAME=AIRA
APP_ENV=production
DEBUG=false
API_PREFIX=/api/v1

# --- Server ---
# Public dashboard origin(s) allowed by CORS. The SPA is served from aira.isiri.rw
# and calls the API at api-aira.isiri.rw, so the API must allow the dashboard origin.
CORS_ORIGINS=https://aira.isiri.rw

# --- Database (reuses the host's CloudPanel MySQL on 127.0.0.1) ---
DATABASE_URL=mysql+pymysql://aira:CHANGE_ME@127.0.0.1:3306/aira

# --- Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_CHARS_MIN
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Uploads ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_BYTES=10485760

# --- Celery / Redis (Redis runs as a container published on 127.0.0.1:6379) ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_USE_REDIS=true

# --- AI (kept off; enable + rebuild with INSTALL_ML=1 to use the vision stack) ---
AI_ENABLED=false

# --- Email / notifications (off by default) ---
EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AIRA <no-reply@aira.isiri.rw>
FCM_SERVER_KEY=

# --- Auto-seed default admin/officer/citizen on first boot ---
AUTO_SEED=true
